# service 共享配置
GRID_PLATFORM_BINANCE_ENABLED=1
GRID_PLATFORM_BINANCE_API_KEY=your_api_key
GRID_PLATFORM_BINANCE_API_SECRET=your_api_secret

# 可选：覆盖 Binance endpoint
# GRID_PLATFORM_BINANCE_REST_BASE_URL=https://demo-fapi.binance.com
# GRID_PLATFORM_BINANCE_WS_BASE_URL=wss://fstream.binancefuture.com

# 可选：服务监听地址
# GRID_PLATFORM_SERVICE_ADDR=127.0.0.1:8000

# 可选：TUI 连接与语言
# GRID_PLATFORM_BASE_URL=http://127.0.0.1:8000
# GRID_PLATFORM_WS_URL=ws://127.0.0.1:8000/ws
# GRID_PLATFORM_UI_LOCALE=zh-CN

# 可选：兼容单实例 mainnet 启动
# GRID_PLATFORM_ALLOW_MAINNET=1
