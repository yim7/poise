{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Track Tuning Workbench",
  "version": "0.1.0",
  "identifier": "com.poise.track-tuning-workbench",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Track Tuning Workbench",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
